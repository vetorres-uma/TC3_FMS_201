    <Action Name="a_ManiobrasPendientes_Calcular" Id="{02a5032b-6e7b-001d-041b-1485fa225e04}">
      <Implementation>
        <ST><![CDATA[IF UnidadesPendientes > 0 THEN
    UnidadesPendientes := UnidadesPendientes - 1;
END_IF;

TareaFinalizada := (UnidadesPendientes = 0);]]></ST>
      </Implementation>
    </Action>
    <Action Name="a_ManiobrasPendientes_Iniciar" Id="{42172e6e-a864-0f61-2d9d-05e86b199c8d}">
      <Implementation>
        <ST><![CDATA[UnidadesPendientes := UnidadesSolicitadas;]]></ST>
      </Implementation>
    </Action>
    <Action Name="a_MarchaAutorizada" Id="{50e82557-1c85-084f-13dd-c0ab9e9e78d6}">
      <Implementation>
        <ST><![CDATA[CondicionInicial := i_DetectorPresion 
    AND i_EstacionConectada
    AND i_EmpujadorDetras
    AND i_VerificadorArriba
    AND i_DesplazadorDetras
    AND i_DescargadorDetras
    AND i_DescargadorArriba;
    
CondicionMarcha := (UnidadesSolicitadas > 0);
MarchaAutorizada := CondicionInicial AND CondicionMarcha;
]]></ST>
      </Implementation>
    </Action>
    <Action Name="a_PiezaCorrecta" Id="{91682ee4-653b-02b9-0fa3-0ca2fab11185}">
      <Implementation>
        <ST><![CDATA[PiezaCorrecta := i_VerificadorAbajo;
]]></ST>
      </Implementation>
    </Action>
