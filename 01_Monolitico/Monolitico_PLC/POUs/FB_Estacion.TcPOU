<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_Estacion" Id="{0900b681-9b01-4b7c-9570-85b5f70c48a2}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_Estacion
VAR_INPUT
	TiempoAjustePale: TIME := T#1S;
	TiempoVerificacion: TIME := T#1S;
	TiempoDesplazador: TIME := T#2S;
END_VAR
VAR_OUTPUT
	i_SelectorManual AT %I*: BOOL;
END_VAR
VAR
    // Variables de entrada
    i_PulsadorEmergencia AT %I*: BOOL;
    //i_SelectorManual AT %I*: BOOL;
    i_PulsadorMarcha AT %I*: BOOL;
    i_PulsadorParada AT %I*: BOOL := TRUE;
    i_EstacionConectada AT %I*: BOOL;
    i_PresenciaPale AT %I*: BOOL;
    i_CodigoPaleBit0 AT %I*: BOOL;
    i_CodigoPaleBit1 AT %I*: BOOL;
    
    i_CodigoPaleBit2 AT %I*: BOOL;
    i_DetectorPresion AT %I*: BOOL := TRUE;
    
    i_DescargadorDetras AT %I*: BOOL := TRUE;
    i_DescargadorDelante AT %I*: BOOL;
    i_DescargadorArriba AT %I*: BOOL := TRUE;
    i_DescargadorAbajo AT %I*: BOOL;
    i_VerificadorArriba AT %I*: BOOL := TRUE;
    i_VerificadorAbajo AT %I*: BOOL;
    i_DesplazadorDetras AT %I*: BOOL := TRUE;
    i_EmpujadorDetras AT %I*: BOOL := TRUE;
    
    i_EmpujadorDelante AT %I*: BOOL;
    i_DescargadorVacio AT %I*: BOOL;
    i_PresenciaBase AT %I*: BOOL;
    
    // Variables de salida
    o_DesconectaEstacion AT %Q*: BOOL;
    o_LamparaAlarma AT %Q*: BOOL;
    o_LamparaMarcha AT %Q*: BOOL;
    o_LamparaMaterial AT %Q*: BOOL;
    o_CintaActiva AT %Q*: BOOL;
    o_CintaInvierte AT %Q*: BOOL;
    o_RetenedorBaja AT %Q*: BOOL;
    o_SeparadorSube AT %Q*: BOOL;
    
    o_AvisadorSonoro AT %Q*: BOOL;

    o_DescargadorAvanza AT %Q*: BOOL;
    o_DescargadorRetrocede AT %Q*: BOOL;
    o_DescargadorBaja AT %Q*: BOOL;
    o_RechazadorAvanza AT %Q*: BOOL;
    o_VerificardorBaja AT %Q*: BOOL;
    o_DesplazadorAvanza AT %Q*: BOOL;
    o_EmpujadorAvanza AT %Q*: BOOL;
    o_DescargadorSucciona AT %Q*: BOOL;    
END_VAR
]]></Declaration>
